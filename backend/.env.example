# ─── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://multisaas:password@localhost:5432/multisaas_db"
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars"
ENCRYPTION_KEY="your-64-char-hex-key-for-aes256"  # generate: openssl rand -hex 32
PORT=4000
NODE_ENV=development
API_BASE_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# ─── Payment Providers ─────────────────────────────────────────────────────────
# Stripe (per-project, stored in DB — but you can set a default here)
STRIPE_DEFAULT_SECRET=""        # sk_live_... or sk_test_...
PAYPAL_ENV="sandbox"            # or "live"

# Paddle
PADDLE_ENV="sandbox"            # or "live"

# ─── Banking ──────────────────────────────────────────────────────────────────
# These are org-level (not per-project) — stored encrypted in DB
MERCURY_API_KEY=""
BREX_API_KEY=""
WISE_API_KEY=""

# Plaid
PLAID_CLIENT_ID="your-client-id"
PLAID_SECRET="your-secret"
PLAID_ENV="sandbox"   # sandbox, development, production

# ─── AI Providers (user-configurable in UI, but defaults here) ────────────────
OPENAI_API_KEY=""               # Optional default
ANTHROPIC_API_KEY=""            # Optional default

# ─── Notifications ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS=""                    # Your Resend/SMTP password
SMTP_FROM="alerts@yourdomain.com"
ALERT_EMAIL="you@yourdomain.com"
SLACK_WEBHOOK_URL=""            # https://hooks.slack.com/services/...

# ─── Optional ─────────────────────────────────────────────────────────────────
REDIS_URL=""                    # For job queuing (optional)
SENTRY_DSN=""                   # Error tracking (optional)
