// db/schema.prisma
// MultiSaaS v2 — Production Database Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String
  avatarUrl        String?
  role             GlobalRole @default(MEMBER)
  isActive         Boolean   @default(true)
  emailVerified    Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  refreshTokens    RefreshToken[]
  projectMembers   ProjectMember[]
  notifications    Notification[]
  aiConfigs        AIConfig[]
  auditLogs        AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum GlobalRole {
  SUPERADMIN
  MEMBER
  OWNER
  ADMIN
  VIEWER
}

// ─────────────────────────────────────────────────────────────
// SAAS PROJECTS
// ─────────────────────────────────────────────────────────────

model Project {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String?
  logo            String?
  website         String?
  status          ProjectStatus @default(ACTIVE)
  currency        String        @default("USD")
  fiscalYearStart Int           @default(1) // month 1-12
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  members         ProjectMember[]
  revenue         RevenueEntry[]
  expenses        ExpenseEntry[]
  metrics         MonthlyMetric[]
  integrations    Integration[]
  ledgerAccounts  LedgerAccount[]
  ledgerEntries   LedgerEntry[]
  aiInsights      AIInsight[]
  webhooks        Webhook[]
  alerts          Alert[]

  @@map("projects")
}

model ProjectMember {
  id          String      @id @default(cuid())
  userId      String
  projectId   String
  role        ProjectRole @default(VIEWER)
  permissions Json?       // fine-grained permission overrides
  joinedAt    DateTime    @default(now())
  invitedBy   String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProjectRole {
  ADMIN
  OPERATOR
  VIEWER
  OWNER
}

// ─────────────────────────────────────────────────────────────
// REVENUE
// ─────────────────────────────────────────────────────────────

model RevenueEntry {
  id             String      @id @default(cuid())
  projectId      String
  amount         Float                         // in smallest currency unit (cents)
  amountDecimal  Float                         // human-readable amount
  currency       String      @default("USD")
  type           RevenueType
  status         PaymentStatus @default(COMPLETED)
  description    String?
  source         String?                       // "stripe", "paypal", "paddle", "manual"
  externalId     String?                       // ID from payment processor
  customerId     String?                       // external customer ID
  customerEmail  String?
  subscriptionId String?                       // for recurring payments
  productId      String?
  planId         String?
  date           DateTime
  periodStart    DateTime?
  periodEnd      DateTime?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, date])
  @@index([externalId, source])
  @@map("revenue_entries")
}

enum RevenueType {
  SUBSCRIPTION
  ONE_TIME
  REFUND
  UPGRADE
  DOWNGRADE
  CREDIT
  CHARGEBACK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

// ─────────────────────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────────────────────

model ExpenseEntry {
  id            String          @id @default(cuid())
  projectId     String
  amount        Float
  currency      String          @default("USD")
  category      ExpenseCategory
  subcategory   String?
  description   String
  vendor        String?
  vendorId      String?
  invoiceNumber String?
  date          DateTime
  recurring     Boolean         @default(false)
  recurringCycle String?        // "monthly", "annual", etc.
  approvedBy    String?
  receiptUrl    String?
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, date])
  @@index([projectId, category])
  @@map("expense_entries")
}

enum ExpenseCategory {
  INFRASTRUCTURE
  MARKETING
  SALARIES
  SOFTWARE
  LEGAL
  SUPPORT
  BANKING
  TAXES
  R_AND_D
  MISC
}

// ─────────────────────────────────────────────────────────────
// INTERNAL LEDGER (double-entry bookkeeping)
// ─────────────────────────────────────────────────────────────

model LedgerAccount {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  code        String          // e.g. "1000", "2000"
  type        LedgerAccountType
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  debitLines  LedgerLine[]    @relation("DebitAccount")
  creditLines LedgerLine[]    @relation("CreditAccount")

  @@unique([projectId, code])
  @@map("ledger_accounts")
}

model LedgerEntry {
  id          String      @id @default(cuid())
  projectId   String
  date        DateTime
  description String
  reference   String?     // ties to revenue/expense entry id
  createdAt   DateTime    @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   LedgerLine[]

  @@index([projectId, date])
  @@map("ledger_entries")
}

model LedgerLine {
  id              String      @id @default(cuid())
  entryId         String
  debitAccountId  String
  creditAccountId String
  amount          Float
  currency        String      @default("USD")
  memo            String?

  entry         LedgerEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  debitAccount  LedgerAccount @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount LedgerAccount @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@map("ledger_lines")
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// ─────────────────────────────────────────────────────────────
// MONTHLY METRICS (Pre-aggregated)
// ─────────────────────────────────────────────────────────────

model MonthlyMetric {
  id               String   @id @default(cuid())
  projectId        String
  year             Int
  month            Int      // 1-12
  mrr              Float    @default(0)
  arr              Float    @default(0)
  totalRevenue     Float    @default(0)
  subscriptionRevenue Float @default(0)
  oneTimeRevenue   Float    @default(0)
  totalRefunds     Float    @default(0)
  totalExpenses    Float    @default(0)
  netProfit        Float    @default(0)
  grossMargin      Float    @default(0)  // percentage
  newCustomers     Int      @default(0)
  churnedCustomers Int      @default(0)
  activeCustomers  Int      @default(0)
  churnRate        Float    @default(0)  // percentage
  ltv              Float    @default(0)  // lifetime value avg
  arpu             Float    @default(0)  // avg revenue per user
  cashBalance      Float    @default(0)  // from banking integration
  burnRate         Float    @default(0)
  runway           Float    @default(0)  // months
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, year, month])
  @@map("monthly_metrics")
}

// ─────────────────────────────────────────────────────────────
// INTEGRATIONS
// ─────────────────────────────────────────────────────────────

model Integration {
  id              String              @id @default(cuid())
  projectId       String
  provider        IntegrationProvider
  status          IntegrationStatus   @default(PENDING)
  displayName     String?
  accountId       String?             // provider-side account id
  accessToken     String?             // AES-256 encrypted
  refreshToken    String?             // AES-256 encrypted
  webhookSecret   String?             // AES-256 encrypted
  webhookId       String?             // registered webhook id at provider
  scope           String[]            // OAuth scopes granted
  metadata        Json?               // provider-specific config
  lastSyncedAt    DateTime?
  syncCursor      String?             // pagination cursor for incremental sync
  errorMessage    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  syncLogs  SyncLog[]

  @@unique([projectId, provider])
  @@map("integrations")
}

model SyncLog {
  id            String      @id @default(cuid())
  integrationId String
  status        SyncStatus
  recordsSynced Int         @default(0)
  errorMessage  String?
  startedAt     DateTime    @default(now())
  completedAt   DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@map("sync_logs")
}

enum IntegrationProvider {
  STRIPE
  PAYPAL
  PADDLE
  BREX
  MERCURY
  WISE
  QUICKBOOKS
  XERO
  PLAID
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
  SYNCING
}

enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILED
}

// ─────────────────────────────────────────────────────────────
// BANKING / CASH POSITIONS
// ─────────────────────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(cuid())
  projectId     String?  // null = global/org level
  provider      String   // "brex", "mercury", "wise"
  accountId     String   // provider account ID
  accountName   String
  accountType   String   // "checking", "savings", "multi-currency"
  currency      String   @default("USD")
  balanceCurrent Float   @default(0)
  balanceAvailable Float @default(0)
  lastUpdatedAt DateTime @default(now())
  metadata      Json?
  createdAt     DateTime @default(now())

  transactions BankTransaction[]

  @@map("bank_accounts")
}

model BankTransaction {
  id            String   @id @default(cuid())
  accountId     String
  externalId    String?  @unique
  amount        Float
  currency      String   @default("USD")
  description   String?
  merchant      String?
  category      String?
  type          String   // "debit", "credit"
  date          DateTime
  pending       Boolean  @default(false)
  metadata      Json?
  createdAt     DateTime @default(now())

  account BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("bank_transactions")
}

// ─────────────────────────────────────────────────────────────
// AI LAYER
// ─────────────────────────────────────────────────────────────

model AIConfig {
  id         String    @id @default(cuid())
  userId     String
  provider   AIProvider
  apiKey     String    // AES-256 encrypted
  model      String    // e.g. "gpt-4o", "claude-3-5-sonnet"
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights AIInsight[]

  @@map("ai_configs")
}

model AIInsight {
  id          String      @id @default(cuid())
  projectId   String
  aiConfigId  String?
  type        InsightType
  title       String
  body        String      @db.Text
  severity    InsightSeverity @default(INFO)
  isRead      Boolean     @default(false)
  isDismissed Boolean     @default(false)
  metadata    Json?
  generatedAt DateTime    @default(now())
  expiresAt   DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiConfig AIConfig? @relation(fields: [aiConfigId], references: [id])

  @@index([projectId, isRead])
  @@map("ai_insights")
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  MISTRAL
  COHERE
  OLLAMA
  CUSTOM
}

enum InsightType {
  COST_OPTIMIZATION
  REVENUE_ALERT
  CHURN_ALERT
  CASH_ALLOCATION
  FORECAST
  ANOMALY
  MILESTONE
  GENERAL
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
  SUCCESS
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS & ALERTS
// ─────────────────────────────────────────────────────────────

model Alert {
  id          String      @id @default(cuid())
  projectId   String
  type        AlertType
  threshold   Float?
  condition   String?     // "gt", "lt", "eq"
  message     String?
  channels    String[]    // ["email", "slack", "webhook"]
  isActive    Boolean     @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  channel   String             // "in_app", "email", "slack"
  isRead    Boolean            @default(false)
  metadata  Json?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Webhook {
  id        String   @id @default(cuid())
  projectId String
  url       String
  events    String[]
  secret    String   // HMAC signing secret
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

enum AlertType {
  LOW_MRR
  HIGH_CHURN
  EXPENSE_SPIKE
  LOW_CASH
  PAYMENT_FAILED
  REFUND_SPIKE
  RUNWAY_LOW
  CUSTOM
}

enum NotificationType {
  ALERT
  INSIGHT
  SYNC_COMPLETE
  SYNC_FAILED
  SYSTEM
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // "project.created", "integration.connected", etc.
  resourceId String?
  resourceType String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resourceId])
  @@map("audit_logs")
}
